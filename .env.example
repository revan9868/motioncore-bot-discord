# ─── DISCORD ───────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here
VIP_ROLE_ID=your_vip_role_id_here

# ─── SUPABASE ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ─── PAKASIR (QRIS Payment Gateway) ────
PAKASIR_SLUG=your_pakasir_project_slug
PAKASIR_API_KEY=your_pakasir_api_key
PAKASIR_IPS=103.xxx.xxx.xxx,104.xxx.xxx.xxx

# ─── WEBHOOK ───────────────────────────
TESTI_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# ─── SERVER ────────────────────────────
PORT=3000
NODE_ENV=development

# ─── LOGGING ───────────────────────────
# Levels: debug | info | warn | error
LOG_LEVEL=info

# ─── TESTING ───────────────────────────
TEST_ORDER_ID=INV-xxxxx
TEST_WEBHOOK_URL=http://localhost:3000/webhook/pakasir
