# ─── DISCORD ───────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here
VIP_ROLE_ID=your_vip_role_id_here

# ─── SUPABASE ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ─── PAKASIR (QRIS Payment Gateway) ────
PAKASIR_SLUG=your_pakasir_project_slug
PAKASIR_API_KEY=your_pakasir_api_key

# ─── WEBHOOK (Discord, not Express) ─────
TESTI_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx
ADMIN_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# ─── MODE ──────────────────────────────
# production = global slash command
# (leave empty or development = guild-specific for instant updates)
NODE_ENV=development

# ─── LOGGING ───────────────────────────
# Levels: debug | info | warn | error
LOG_LEVEL=info
